{
  "version": 8,
  "name": "OSM + West Hyderabad Layers",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "raster",
      "tiles": [
        "https://a.tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "&copy; OpenStreetMap Contributors"
    },
    "schools-source": {
      "type": "vector",
      "url": "pmtiles://maptiles/schools.pmtiles"
    },
    "highways-source": {
      "type": "vector",
      "url": "pmtiles://maptiles/highways.pmtiles"
    },
    "metro-source": {
      "type": "vector",
      "url": "pmtiles://maptiles/metro.pmtiles"
    },
    "orr-source": {
      "type": "vector",
      "url": "pmtiles://maptiles/orr.pmtiles"
    },
    "lakes-source": {
      "type": "vector",
      "url": "pmtiles://maptiles/lakes.pmtiles"
    }
  },
  "layers": [
    {
      "id": "osm-base",
      "type": "raster",
      "source": "osm"
    },
    {
      "id": "lakes-layer",
      "type": "fill",
      "source": "lakes-source",
      "source-layer": "lakes",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "#0ea5e9",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "orr-layer",
      "type": "line",
      "source": "orr-source",
      "source-layer": "orr",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#3b82f6",
        "line-width": 6,
        "line-opacity": 0.9
      }
    },
    {
      "id": "highways-layer",
      "type": "line",
      "source": "highways-source",
      "source-layer": "highways",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#faa916",
        "line-width": 2.5,
        "line-opacity": 0.8
      }
    },
    {
      "id": "metro-layer",
      "type": "line",
      "source": "metro-source",
      "source-layer": "metro",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#ef4444",
        "line-width": 5,
        "line-blur": 1
      }
    },
    {
      "id": "schools-layer",
      "type": "circle",
      "source": "schools-source",
      "source-layer": "schools",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "circle-radius": 5,
        "circle-color": "#a855f7",
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#ffffff",
        "circle-opacity": 0.9
      }
    }
  ]
}